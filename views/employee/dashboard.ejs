<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Dashboard - Marquardt India Pvt. Ltd.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <%- include('../partials/navbar') %>
    
    <main class="ml-0 lg:ml-64 flex flex-col h-screen">
        <!-- Fixed Header Section -->
        <div class="flex-shrink-0 p-4 sm:p-6 bg-gray-50 border-b border-gray-200">
            <%- include('../partials/messages') %>
            
            <div class="mb-4 flex justify-between items-start">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Employee Dashboard</h1>
                    <p class="text-gray-600">Welcome back, <%= user.full_name %>!</p>
                </div>
            </div>
        </div>
        
        <!-- Scrollable Content Area -->
        <div class="flex-1 overflow-y-auto p-4 sm:p-6">

            
            <!-- Dashboard Cards -->
        <div class="flex justify-center items-start min-h-full">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8 w-full max-w-md sm:max-w-2xl lg:max-w-4xl">
            <!-- Employee Profile Card -->
            <a href="/employee/account" class="group">
                <div class="bg-white hover:bg-teal-50 rounded-lg shadow hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-[#009A9A] aspect-square">
                    <div class="text-center h-full flex flex-col justify-center items-center">
                        <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center mb-1">
                            <i class="fas fa-user text-lg text-[#009A9A]"></i>
                        </div>
                        <h3 class="text-base font-medium text-gray-800">Employee Profile</h3>
                        <p class="text-xs text-gray-500">View personal information</p>
                    </div>
                </div>
            </a>

            <!-- My Products Card -->
            <a href="/employee/my-products" class="group">
                <div class="bg-white hover:bg-teal-50 rounded-lg shadow hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-[#009A9A] aspect-square">
                    <div class="text-center h-full flex flex-col justify-center items-center">
                        <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center mb-1">
                            <i class="fas fa-laptop text-lg text-[#009A9A]"></i>
                        </div>
                        <h3 class="text-base font-medium text-gray-800">My Products</h3>
                        <p class="text-xs text-gray-500"><span id="dashboardActiveProducts">0</span> Active Products</p>
                    </div>
                </div>
            </a>
            
            <!-- View Stock Card -->
            <a href="/employee/stock" class="group">
                <div class="bg-white hover:bg-teal-50 rounded-lg shadow hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-[#009A9A] aspect-square">
                    <div class="text-center h-full flex flex-col justify-center items-center">
                        <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center mb-1">
                            <i class="fas fa-boxes text-lg text-[#009A9A]"></i>
                        </div>
                        <h3 class="text-base font-medium text-gray-800">View Stock</h3>
                        <p class="text-xs text-gray-500">Browse available inventory</p>
                    </div>
                </div>
            </a>

            <!-- View Records Card -->
            <a href="/employee/records" class="group">
                <div class="bg-white hover:bg-teal-50 rounded-lg shadow hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-[#009A9A] aspect-square">
                    <div class="text-center h-full flex flex-col justify-center items-center">
                        <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center mb-1">
                            <i class="fas fa-history text-lg text-[#009A9A]"></i>
                        </div>
                        <h3 class="text-base font-medium text-gray-800">View Records</h3>
                        <p class="text-xs text-gray-500"><span id="dashboardPendingRequests">0</span> Pending Requests</p>
                    </div>
                </div>
            </a>

            <!-- HIL Labs Card -->
            <a href="/hil/labs" class="group">
                <div class="bg-white hover:bg-teal-50 rounded-lg shadow hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-[#009A9A] aspect-square">
                    <div class="text-center h-full flex flex-col justify-center items-center">
                        <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center mb-1">
                            <i class="fas fa-flask text-lg text-[#009A9A]"></i>
                        </div>
                        <h3 class="text-base font-medium text-gray-800">HIL Labs</h3>
                        <p class="text-xs text-gray-500">Book testing facilities</p>
                    </div>
                </div>
            </a>

            <!-- My HIL Bookings Card -->
            <a href="/hil/my-bookings" class="group">
                <div class="bg-white hover:bg-teal-50 rounded-lg shadow hover:shadow-md transition-all duration-200 border border-gray-200 hover:border-[#009A9A] aspect-square">
                    <div class="text-center h-full flex flex-col justify-center items-center">
                        <div class="w-12 h-12 bg-teal-50 rounded-full flex items-center justify-center mb-1">
                            <i class="fas fa-calendar-check text-lg text-[#009A9A]"></i>
                        </div>
                        <h3 class="text-base font-medium text-gray-800">My HIL Bookings</h3>
                        <p class="text-xs text-gray-500"><span id="dashboardHilBookings">0</span> Active Bookings</p>
                    </div>
                </div>
            </a>
            </div>
        </div>
        </div> <!-- End scrollable content area -->
    </main>
    
    <script>
        // Function to update dashboard stats
        async function updateDashboardStats() {
            try {
                // Update active products count
                const activeProductsResponse = await fetch('/employee/api/active-products-count');
                if (activeProductsResponse.ok) {
                    const activeProductsData = await activeProductsResponse.json();
                    const dashboardActiveProducts = document.getElementById('dashboardActiveProducts');
                    if (dashboardActiveProducts) {
                        dashboardActiveProducts.textContent = activeProductsData.count;
                    }
                }

                // Update pending requests count
                const pendingRequestsResponse = await fetch('/employee/api/pending-requests-count');
                if (pendingRequestsResponse.ok) {
                    const pendingRequestsData = await pendingRequestsResponse.json();
                    const dashboardPendingRequests = document.getElementById('dashboardPendingRequests');
                    if (dashboardPendingRequests) {
                        dashboardPendingRequests.textContent = pendingRequestsData.count;
                    }
                }

                // Update HIL bookings count
                const hilBookingsResponse = await fetch('/employee/api/hil-bookings-count');
                if (hilBookingsResponse.ok) {
                    const hilBookingsData = await hilBookingsResponse.json();
                    const dashboardHilBookings = document.getElementById('dashboardHilBookings');
                    if (dashboardHilBookings) {
                        dashboardHilBookings.textContent = hilBookingsData.count;
                    }
                }
            } catch (error) {
                console.error('Error updating dashboard stats:', error);
            }
        }
        
        // Update stats every 30 seconds
        setInterval(updateDashboardStats, 30000);
        
        // Update stats when page loads
        document.addEventListener('DOMContentLoaded', updateDashboardStats);
    </script>
</body>
</html>