<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My History - Marquardt India Pvt. Ltd.</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <%- include('../partials/navbar') %>
    
    <main class="ml-0 lg:ml-64 flex flex-col h-screen">
        <!-- Fixed Header Section -->
        <div class="flex-shrink-0 p-4 sm:p-6 bg-gray-50 border-b border-gray-200">
            <%- include('../partials/messages') %>
            
            <div class="mb-4">
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">My History</h1>
                <p class="text-gray-600">Your personal request and assignment history</p>
            </div>
        </div>
        
        <!-- Scrollable Content Area -->
        <div class="flex-1 overflow-y-auto p-4 sm:p-6">
        
        <!-- My Product Requests -->
        <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
            <div class="px-4 py-5 sm:p-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">My Product Requests (<%= myRequests.length %> items)</h3>
                <div class="overflow-x-auto w-full">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Purpose</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Requested Date</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Processed By</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Processed Date</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remarks</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            <% if (myRequests && myRequests.length > 0) { %>
                                <% myRequests.forEach(request => { %>
                                    <tr>
                                        <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                            <%= request.product_name || 'N/A' %>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-gray-500">
                                            <%= request.purpose || 'No purpose specified' %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                            <%= request.formatted_requested_at || 'N/A' %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <% if (request.status === 'approved') { %>
                                                <span class="text-xs font-medium text-green-600">✓ Approved</span>
                                            <% } else if (request.status === 'rejected') { %>
                                                <span class="text-xs font-medium text-red-600">✗ Rejected</span>
                                            <% } else { %>
                                                <span class="text-xs font-medium text-yellow-600">⏳ Pending</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                            <%= request.processed_by_name || 'Not processed' %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                            <%= request.formatted_processed_at || 'Not processed' %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (request.remarks && request.remarks !== 'null' && request.remarks.trim() !== '') { %>
                                                <div class="bg-gray-50 p-2 rounded text-xs border-l-2 border-blue-400">
                                                    <%= request.remarks %>
                                                </div>
                                            <% } else { %>
                                                <span class="text-gray-400 text-sm">No remarks</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">
                                        No request history found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Tabbed Records Section -->
        <div class="bg-white shadow rounded-lg">
            <div class="px-4 py-5 sm:p-6">
                <!-- Tab Navigation -->
                <div class="border-b border-gray-200 mb-4">
                    <nav class="-mb-px flex space-x-8">
                        <button onclick="showTab('assignments')" id="assignments-tab" class="tab-button active py-2 px-1 border-b-2 border-blue-500 font-medium text-sm text-blue-600">
                            My Assignments
                        </button>
                        <button onclick="showTab('extensions')" id="extensions-tab" class="tab-button py-2 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300">
                            Extension Requests
                        </button>
                    </nav>
                </div>

                <!-- Assignments Tab -->
                <div id="assignments-content" class="tab-content">
                    <div class="max-h-96 overflow-y-auto">
                        <table class="w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned By</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned Date</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Return Date</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Returned Date</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remarks</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% if (myAssignments && myAssignments.length > 0) { %>
                                    <% myAssignments.forEach(assignment => { %>
                                        <tr>
                                            <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                                <%= assignment.product_name || 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <%= assignment.monitor_name || 'Unknown' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <%= assignment.formatted_assigned_at || 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <% if (assignment.return_date) { %>
                                                    <%= new Date(assignment.return_date).toLocaleDateString() %>
                                                <% } else { %>
                                                    <span class="text-gray-400">N/A</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <% if (assignment.is_returned) { %>
                                                    <span class="text-xs font-medium text-green-600">✓ Returned</span>
                                                <% } else if (assignment.remarks === 'RETURN_REQUESTED') { %>
                                                    <span class="text-xs font-medium text-yellow-600">⏳ Return Requested</span>
                                                <% } else if (assignment.remarks && assignment.remarks.startsWith('RETURN_REJECTED')) { %>
                                                    <span class="text-xs font-medium text-red-600">✗ Return Rejected</span>
                                                <% } else { %>
                                                    <span class="text-xs font-medium text-blue-600">📦 In Use</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <%= assignment.formatted_returned_at || 'Not returned' %>
                                            </td>
                                            <td class="px-6 py-4">
                                                <% if (assignment.remarks && assignment.remarks.startsWith('RETURN_REJECTED')) { %>
                                                    <div class="bg-red-50 p-2 rounded text-xs border-l-2 border-red-400">
                                                        <strong>Rejection Reason:</strong><br>
                                                        <%= assignment.remarks.replace('RETURN_REJECTED: ', '') %>
                                                    </div>
                                                <% } else if (assignment.remarks && assignment.remarks !== 'null' && assignment.remarks.trim() !== '') { %>
                                                    <div class="bg-gray-50 p-2 rounded text-xs border-l-2 border-green-400">
                                                        <%= assignment.remarks %>
                                                    </div>
                                                <% } else { %>
                                                    <span class="text-gray-400 text-sm">No remarks</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-500">
                                                <% if (assignment.is_returned) { %>
                                                    <span class="text-gray-400">Returned</span>
                                                <% } else if (assignment.remarks === 'RETURN_REQUESTED') { %>
                                                    <span class="text-orange-600">Pending Approval</span>
                                                <% } else if (assignment.remarks && assignment.remarks.startsWith('RETURN_REJECTED')) { %>
                                                    <form action="/monitor/return-product" method="POST" onsubmit="return confirm('Your previous return request was rejected. Do you want to request return again?');">
                                                        <input type="hidden" name="assignment_id" value="<%= assignment.assignment_id %>" />
                                                        <button type="submit" class="text-blue-600 hover:text-blue-800 text-xs font-medium">
                                                            ↩ Return
                                                        </button>
                                                    </form>
                                                <% } else { %>
                                                    <form action="/monitor/return-product" method="POST" onsubmit="return confirm('Are you sure you want to request return of this product?');">
                                                        <input type="hidden" name="assignment_id" value="<%= assignment.assignment_id %>" />
                                                        <button type="submit" class="text-blue-600 hover:text-blue-800 text-xs font-medium">
                                                            ↩ Return
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">
                                            No assignment history found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Extensions Tab -->
                <div id="extensions-content" class="tab-content hidden">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">My Extension Request History</h3>
                    <div class="max-h-96 overflow-y-auto">
                        <table class="w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Original Return Date</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">New Return Date</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reason</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Requested Date</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% if (myExtensionRequests && myExtensionRequests.length > 0) { %>
                                    <% myExtensionRequests.forEach(extension => { %>
                                        <tr>
                                            <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                                <%= extension.product_name || 'N/A' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <% if (extension.return_date) { %>
                                                    <%= new Date(extension.return_date).toLocaleDateString() %>
                                                <% } else { %>
                                                    N/A
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <% if (extension.new_return_date) { %>
                                                    <%= new Date(extension.new_return_date).toLocaleDateString() %>
                                                <% } else { %>
                                                    N/A
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-500">
                                                <%= extension.extension_reason || 'No reason provided' %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <% if (extension.extension_status === 'approved') { %>
                                                    <span class="text-xs font-medium text-green-600">✓ Approved</span>
                                                <% } else if (extension.extension_status === 'rejected') { %>
                                                    <span class="text-xs font-medium text-red-600">✗ Rejected</span>
                                                <% } else { %>
                                                    <span class="text-xs font-medium text-yellow-600">⏳ Pending</span>
                                                <% } %>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                                <% if (extension.extension_requested_at) { %>
                                                    <%= new Date(extension.extension_requested_at).toLocaleDateString() %>
                                                <% } else { %>
                                                    N/A
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">
                                            No extension requests found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        </div>
    </main>

    <script>
        function showTab(tabName) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
            });
            
            // Remove active class from all tabs
            document.querySelectorAll('.tab-button').forEach(button => {
                button.classList.remove('active', 'border-blue-500', 'text-blue-600');
                button.classList.add('border-transparent', 'text-gray-500');
            });
            
            // Show selected tab content
            document.getElementById(tabName + '-content').classList.remove('hidden');
            
            // Add active class to selected tab
            const activeTab = document.getElementById(tabName + '-tab');
            activeTab.classList.add('active', 'border-blue-500', 'text-blue-600');
            activeTab.classList.remove('border-transparent', 'text-gray-500');
        }
    </script>

</body>
</html>